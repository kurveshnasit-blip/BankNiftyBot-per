<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <!-- App Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🤖 BankNifty Bot"
            android:textSize="32sp"
            android:textStyle="bold"
            android:gravity="center"
            android:textColor="#2196F3"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Intraday Options Automation"
            android:textSize="16sp"
            android:gravity="center"
            android:textColor="#757575"
            android:layout_marginBottom="48dp" />

        <!-- Login Section (Visible initially) -->
        <LinearLayout
            android:id="@+id/loginContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="24dp"
            android:layout_marginBottom="32dp">

            <EditText
                android:id="@+id/emailEditText"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:hint="📧 Email"
                android:inputType="textEmailAddress"
                android:background="@drawable/edittext_background"
                android:padding="16dp"
                android:layout_marginBottom="16dp" />

            <EditText
                android:id="@+id/passwordEditText"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:hint="🔒 Password"
                android:inputType="textPassword"
                android:background="@drawable/edittext_background"
                android:padding="16dp"
                android:layout_marginBottom="24dp" />

            <Button
                android:id="@+id/loginButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="LOGIN"
                android:textSize="18sp"
                android:textStyle="bold"
                android:backgroundTint="#2196F3"
                app:cornerRadius="28dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="admin / admin123"
                android:textSize="12sp"
                android:textColor="#757575"
                android:gravity="center"
                android:layout_marginTop="12dp" />

        </LinearLayout>

        <!-- Dashboard Section (Visible after login) -->
        <LinearLayout
            android:id="@+id/dashboardContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- Status Cards -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/status_card_green"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:layout_marginEnd="12dp">

                    <TextView
                        android:id="@+id/serviceStatusText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="🔴 STOPPED"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@android:color/white"
                        android:gravity="center" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/status_card_blue"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:layout_marginStart="12dp">

                    <TextView
                        android:id="@+id/walletBalanceText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="💰 ₹0"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@android:color/white"
                        android:gravity="center" />

                </LinearLayout>

            </LinearLayout>

            <!-- Control Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <Button
                    android:id="@+id/startServiceButton"
                    android:layout_width="0dp"
                    android:layout_height="60dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="12dp"
                    android:text="🚀 START BOT"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:backgroundTint="#4CAF50"
                    app:cornerRadius="30dp" />

                <Button
                    android:id="@+id/stopServiceButton"
                    android:layout_width="0dp"
                    android:layout_height="60dp"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:text="⏹️ STOP BOT"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:backgroundTint="#F44336"
                    app:cornerRadius="30dp" />

            </LinearLayout>

            <!-- Navigation Buttons -->
            <Button
                android:id="@+id/settingsButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="⚙️ SETTINGS"
                android:textSize="16sp"
                android:layout_marginBottom="12dp"
                android:backgroundTint="#FF9800"
                app:cornerRadius="28dp" />

            <Button
                android:id="@+id/historyButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="📊 TRADE HISTORY"
                android:textSize="16sp"
                android:backgroundTint="#9C27B0"
                app:cornerRadius="28dp" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>