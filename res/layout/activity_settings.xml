<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F8F9FA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginBottom="32dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚙️"
                android:textSize="36sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Trading Settings"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#1E293B"
                android:gravity="center"
                android:layout_marginTop="4dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Configure broker, lots & trading mode"
                android:textSize="14sp"
                android:textColor="#64748B"
                android:gravity="center" />

        </LinearLayout>

        <!-- Broker Selection -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Broker"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#1E293B"
                    android:layout_marginBottom="12dp" />

                <Spinner
                    android:id="@+id/brokerSpinner"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/spinner_background" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- API Credentials -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="API Credentials"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#1E293B"
                    android:layout_marginBottom="16dp" />

                <EditText
                    android:id="@+id/apiKeyEditText"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:hint="API Key"
                    android:inputType="text"
                    android:background="@drawable/edittext_background"
                    android:padding="16dp"
                    android:layout_marginBottom="16dp" />

                <EditText
                    android:id="@+id/apiSecretEditText"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:hint="API Secret"
                    android:inputType="textPassword"
                    android:background="@drawable/edittext_background"
                    android:padding="16dp"
                    android:layout_marginBottom="20dp" />

                <Button
                    android:id="@+id/testConnectionButton"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="🔌 TEST CONNECTION"
                    android:textSize="16sp"
                    android:backgroundTint="#2196F3"
                    app:cornerRadius="24dp" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Trading Parameters -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Trading Parameters"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#1E293B"
                    android:layout_marginBottom="16dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Lots"
                        android:textSize="16sp"
                        android:textColor="#374151" />

                    <EditText
                        android:id="@+id/lotsEditText"
                        android:layout_width="80dp"
                        android:layout_height="48dp"
                        android:inputType="number"
                        android:text="1"
                        android:gravity="center"
                        android:maxLength="2"
                        android:background="@drawable/number_input_background" />

                </LinearLayout>

                <Switch
                    android:id="@+id/modeSwitch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="LIVE TRADING MODE"
                    android:textSize="16sp"
                    android:textColor="#EF4444"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="⚠️ OFF = SIMULATION (Recommended for testing)"
                    android:textSize="12sp"
                    android:textColor="#DC2626"
                    android:gravity="center" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Action Buttons -->
        <Button
            android:id="@+id/saveButton"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="💾 SAVE & APPLY SETTINGS"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp"
            android:backgroundTint="#10B981"
            app:cornerRadius="30dp" />

        <Button
            android:id="@+id/clearHistoryButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="🗑️ CLEAR TRADE HISTORY"
            android:textSize="16sp"
            android:backgroundTint="#6B7280"
            app:cornerRadius="28dp" />

    </LinearLayout>

</ScrollView>